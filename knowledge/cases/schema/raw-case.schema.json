{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OPC Raw Case",
  "type": "object",
  "required": [
    "id",
    "source_id",
    "url",
    "title",
    "captured_at",
    "language",
    "raw_signal",
    "evidence_type",
    "rights_note"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^raw_[a-z0-9_]+$" },
    "source_id": { "type": "string", "pattern": "^src_[a-z0-9_]+$" },
    "url": { "type": "string", "format": "uri" },
    "title": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "language": { "type": "string", "minLength": 2 },
    "raw_signal": { "type": "string", "minLength": 1, "maxLength": 600 },
    "evidence_type": { "type": "string", "minLength": 1 },
    "rights_note": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
