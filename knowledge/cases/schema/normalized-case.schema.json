{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OPC Normalized Case",
  "type": "object",
  "required": [
    "id",
    "raw_ids",
    "name",
    "founder_type",
    "geography",
    "target_user",
    "product_form",
    "route",
    "acquisition",
    "delivery",
    "pricing",
    "evidence_urls",
    "summary",
    "commercial_path",
    "risks",
    "confidence",
    "date_checked"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^case_[a-z0-9_]+$" },
    "raw_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "name": { "type": "string", "minLength": 1 },
    "founder_type": { "type": "string", "minLength": 1 },
    "geography": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "target_user": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "product_form": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "route": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "acquisition": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "delivery": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "pricing": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "evidence_urls": { "type": "array", "items": { "type": "string", "format": "uri" }, "minItems": 1 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 700 },
    "commercial_path": { "type": "string", "minLength": 1 },
    "risks": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "confidence": { "enum": ["low", "medium", "high"] },
    "date_checked": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "additionalProperties": false
}
