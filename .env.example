# ════════════════════════════════════════════════════════════════
# Book of Elon — environment template
# 复制为 .env，填上真实值。生产环境强烈建议直接 export 系统环境变量，
# 不要把真 .env 部署上去。
# ════════════════════════════════════════════════════════════════

# ───────── DeepSeek（必填，否则 AI 走本地降级回复） ─────────
DEEPSEEK_API_KEY=sk-replace_with_real_key_from_deepseek
DEEPSEEK_MODEL=deepseek-chat
# R-01: 单次回复 token 上限（700 是历史值，400 是 2026-04-27 后的推荐值，
# 配合 sanitizeMessages 单条 800 字符上限，单次成本可预测）
DEEPSEEK_MAX_TOKENS=400
DEEPSEEK_TEMPERATURE=0.7

# ───────── 用户会话签名（必填，生产 32+ 字符） ─────────
# 用 `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` 生成
# 一旦修改，所有用户的登录 token 会立即失效
USER_SESSION_SECRET=replace_with_64_hex_chars_minimum_32_long

# ───────── 阿里云短信（生产必填，dev 不填则用 mock 控制台输出） ─────────
SMS_PROVIDER=aliyun
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# ───────── 服务进程 ─────────
PORT=3000
NODE_ENV=development          # 生产请设为 production

# ───────── 性能/限流（保留默认即可） ─────────
UPSTREAM_TIMEOUT_MS=15000
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX_REQUESTS=8
CHAT_BURST_WINDOW_MS=10000
CHAT_BURST_MAX_REQUESTS=3
CHAT_CACHE_TTL_MS=120000
CIRCUIT_BREAKER_FAIL_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=30000
SLOW_REQUEST_THRESHOLD_MS=4000
CHAT_TOKEN_TTL_MS=21600000

# ───────── 成本守门 (R-01, 2026-04 DeepSeek ¥100 事件后引入) ─────────
# 全站每日 token 总额：默认 2,000,000 ≈ ¥10/天硬上限。超过 → 全站降级
DAILY_TOTAL_TOKEN_BUDGET=2000000
# 单 IP 每日 token 配额：默认 50,000，正常用户极难触及
DAILY_TOKEN_PER_IP=50000
# 匿名 session 每日 chat 次数（登录用户不受此限）
DAILY_ANON_CHAT_PER_SESSION=20

# ───────── 数据库（默认 ./data/app.db，集成测试自动用 ./data/test.db） ─────────
# SQLITE_DB_PATH=/var/lib/book-of-elon/app.db

# ───────── 提示词版本（v1=旧版，v2=Elon 强势风格，默认 v2） ─────────
PROMPT_VERSION=v2
