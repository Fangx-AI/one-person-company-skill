{
  "name": "one-person-company-skill",
  "version": "0.1.0",
  "private": false,
  "description": "一人公司Skill：面向独立创业者的产品判断、相似案例、定价获客与商业化可行性分析。",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run opc:repo:test && npm run opc:skill:test && npm run opc:validate:cases:seed && npm run opc:validate:github-sources && npm run opc:eval:answers && npm run opc:idea:test && npm run opc:market:test && npm run opc:case-importer:test && npm run opc:case-collector:test",
    "opc:repo:test": "node tests/opc/repository-boundary.test.js",
    "opc:skill:test": "node tests/opc/skill-surface.test.js",
    "opc:validate:cases": "node scripts/opc/validate-case-intelligence.js",
    "opc:validate:cases:seed": "node scripts/opc/validate-case-intelligence.js --min-sources=30 --min-raw=100 --min-normalized=100 --min-gold=30",
    "opc:validate:github-sources": "node scripts/opc/validate-github-sources.js --min-sources=8 --min-signals=12",
    "opc:github-sources:test": "node tests/opc/github-sources-validator.test.js",
    "opc:collect:candidates": "node scripts/opc/collect-case-candidates.js",
    "opc:collect:candidates:dry": "node scripts/opc/collect-case-candidates.js --dry-run",
    "opc:import:cases": "node scripts/opc/import-case-candidates.js",
    "opc:import:cases:dry": "node scripts/opc/import-case-candidates.js --dry-run",
    "opc:case:index": "node scripts/opc/build-case-index.js",
    "opc:idea:match": "node scripts/opc/match-product-idea.js",
    "opc:idea:test": "node tests/opc/product-idea-matcher.test.js",
    "opc:market:test": "node tests/opc/market-patterns.test.js",
    "opc:case-importer:test": "node tests/opc/case-importer.test.js",
    "opc:case-collector:test": "node tests/opc/case-candidate-url-collector.test.js",
    "opc:eval:answers": "node scripts/opc/validate-answer-quality-evals.js --min-scenarios=13 --min-gold-answers=5",
    "opc:eval:test": "node tests/opc/answer-quality-evals.test.js",
    "opc:case-validator:test": "node tests/opc/case-intelligence-validator.test.js"
  }
}
