{
  "name": "book-of-elon-chat",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "start:monitor": "node monitor-server.js",
    "dev": "node server.js",
    "preflight": "node preflight-check.js",
    "preflight:degraded": "node preflight-check.js --allow-degraded",
    "preflight:prod": "node preflight-check.js --strict-production",

    "smoke:chat": "node tests/calibration/deepseek-smoke-test.js",
    "smoke:auth": "node tests/smoke/auth.js",
    "smoke:db": "node tests/smoke/db.js",
    "smoke:persistence": "node tests/smoke/persistence.js",
    "smoke:northstar": "node tests/smoke/northstar.js",
    "smoke:cost": "node tests/smoke/cost-control.js",
    "smoke:static": "node tests/smoke/static-security.js",
    "smoke:prompt": "node tests/smoke/prompt-injection.js",

    "auth:smoke": "node tests/smoke/auth.js",
    "persist:smoke": "node tests/smoke/persistence.js",
    "northstar:smoke": "node tests/smoke/northstar.js",
    "cost:smoke": "node tests/smoke/cost-control.js",
    "static:smoke": "node tests/smoke/static-security.js",
    "prompt:smoke": "node tests/smoke/prompt-injection.js",

    "test:reply": "node tests/calibration/reply-calibration.js",
    "test:deepseek": "node tests/calibration/deepseek-eval.js",
    "test:e2e": "node tests/e2e/full-flow.js",
    "test:integration": "node tests/e2e/integration-memory.js",
    "test:fact-extractor": "node tests/e2e/fact-extractor.js",

    "probe:live-chat": "node tests/probe/live-chat.js",
    "probe:prompt-injection": "node tests/probe/prompt-injection-live.js",
    "probe:min": "node tests/probe/min.js",

    "db:init": "node scripts/ops/init-db.js",
    "db:smoke": "node tests/smoke/db.js",
    "db:backup": "node scripts/ops/backup-db.js",
    "db:migrate": "node scripts/ops/migrate.js",
    "db:migrate:apply": "node scripts/ops/migrate.js --apply",
    "db:dr-drill": "node scripts/ops/dr-drill.js",

    "opc:validate:cases": "node scripts/opc/validate-case-intelligence.js --target=v0.1",
    "opc:validate:cases:smoke": "node scripts/opc/validate-case-intelligence.js",
    "opc:validate:cases:seed": "node scripts/opc/validate-case-intelligence.js --min-sources=30 --min-raw=100 --min-normalized=100 --min-gold=30",
    "opc:collect:candidates": "node scripts/opc/collect-case-candidates.js",
    "opc:collect:candidates:dry": "node scripts/opc/collect-case-candidates.js --dry-run",
    "opc:import:cases": "node scripts/opc/import-case-candidates.js",
    "opc:import:cases:dry": "node scripts/opc/import-case-candidates.js --dry-run",
    "opc:case:index": "node scripts/opc/build-case-index.js",
    "opc:idea:match": "node scripts/opc/match-product-idea.js",
    "opc:eval:answers": "node scripts/opc/validate-answer-quality-evals.js --min-scenarios=12 --min-gold-answers=4",
    "opc:case:context:test": "node tests/opc/case-context.test.js && node tests/opc/case-context-server-boundary.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
